              <groupfilter function='member' level='[none:Calculation_5476062196363266:nk]' member='&quot;Inactive 12mo+&quot;' />
              <groupfilter function='member' level='[none:Calculation_5476062196363266:nk]' member='&quot;Inactive 6mo+&quot;' />
            </groupfilter>
          </filter>
          <slices>
