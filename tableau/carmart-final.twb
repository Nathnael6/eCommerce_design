    <worksheet name='inactivePurchases'>
      <layout-options>
        <title>
          <formatted-text>
            <run>What did Inactive Users Purchase?</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='online_car_marketplace_TABLEAU (1)' name='federated.1pjtlim1wtdbxy1gy5z3h12r7xtz' />
          </datasources>
          <datasource-dependencies datasource='federated.1pjtlim1wtdbxy1gy5z3h12r7xtz'>
            <column caption='activityStatus' datatype='string' name='[Calculation_5476062196363266]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([customer_last_purchase]) THEN &quot;Never purchased&quot;&#10;ELSEIF DATEDIFF(&apos;month&apos;,[customer_last_purchase],TODAY()) &gt; 12 THEN &quot;Inactive 12mo+&quot;&#10;ELSEIF DATEDIFF(&apos;month&apos;,[customer_last_purchase],TODAY()) &gt; 6 THEN &quot;Inactive 6mo+&quot;&#10;ELSEIF DATEDIFF(&apos;month&apos;,[customer_last_purchase],TODAY()) &gt; 3 THEN &quot;Inactive 3mo+&quot;&#10;ELSE &quot;Active&quot; END' />
            </column>
            <column caption='Body Style' datatype='string' name='[body_style]' role='dimension' type='nominal' />
            <column caption='Customer Last Purchase' datatype='datetime' name='[customer_last_purchase]' role='dimension' type='ordinal' />
            <column caption='Make Model' datatype='string' name='[make_model]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_5476062196363266]' derivation='None' name='[none:Calculation_5476062196363266:nk]' pivot='key' type='nominal' />
            <column-instance column='[body_style]' derivation='None' name='[none:body_style:nk]' pivot='key' type='nominal' />
            <column-instance column='[make_model]' derivation='None' name='[none:make_model:nk]' pivot='key' type='nominal' />
            <column caption='Sale Price' datatype='real' name='[sale_price]' role='measure' type='quantitative' />
            <column-instance column='[sale_price]' derivation='Sum' name='[sum:sale_price:qk]' pivot='key' type='quantitative' />
