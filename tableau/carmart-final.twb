      <aliases enabled='yes' />
      <column caption='UnitsSold' datatype='integer' name='[Calculation_5476062196097024]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [transaction_status] = &quot;Completed&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='DiscountedSales' datatype='real' name='[Calculation_5476062196264961]' role='measure' type='quantitative'>
