              <calculation class='tableau' formula='IF ISNULL([customer_last_purchase]) THEN &quot;Never purchased&quot;&#10;ELSEIF DATEDIFF(&apos;month&apos;,[customer_last_purchase],TODAY()) &gt; 12 THEN &quot;Inactive 12mo+&quot;&#10;ELSEIF DATEDIFF(&apos;month&apos;,[customer_last_purchase],TODAY()) &gt; 6 THEN &quot;Inactive 6mo+&quot;&#10;ELSEIF DATEDIFF(&apos;month&apos;,[customer_last_purchase],TODAY()) &gt; 3 THEN &quot;Inactive 3mo+&quot;&#10;ELSE &quot;Active&quot; END' />
